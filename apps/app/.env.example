NODE_ENV=
BASE_URL="https://app.jiwen.localhost"
JWT_SECRET=

# Auth
BETTER_AUTH_SECRET=

# DB
DATABASE_PRIMARY_URL=
DATABASE_REPLICA_1_URL=
DATABASE_REPLICA_2_URL=

# Alibaba Cloud OSS (S3-compatible)
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
STORAGE_BASE_URL=

# Alibaba Cloud Direct Mail (SMTP)
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Alibaba Cloud Tair (Redis-compatible, Bun RedisClient)
REDIS_URL=redis://:password@host:6379
