{
  "name": "app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless",
    "dev:app": "bun --bun vite dev --host ${HOST:-127.0.0.1} --port ${PORT:-5173}",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "start": "bun run .output/server/index.mjs",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "vitest",
    "db:generate": "bun run --filter @jiwen/db db:generate",
    "db:migrate": "bun run --filter @jiwen/db db:migrate",
    "db:studio": "bun run --filter @jiwen/db db:studio",
    "auth:generate": "bunx --bun @better-auth/cli generate --config ./src/lib/auth/server.ts --output ../../packages/db/src/schemas/auth-schema.ts"
  },
