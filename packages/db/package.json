{
  "name": "@jiwen/db",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./*": "./src/*.ts",
    "./schemas": "./src/schemas/index.ts",
    "./schemas/*": "./src/schemas/*.ts"
  },
  "scripts": {
    "db:sync-sqlc-schema": "node ./scripts/sync-sqlc-schema.js",
    "db:generate": "drizzle-kit generate --name=$NAME && bun run db:sync-sqlc-schema",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:check-sqlc-schema": "bun run db:sync-sqlc-schema && git diff --exit-code -- sqlc/schema.sql"
  },
  "author": "Jiwen",
  "license": "ISC",
  "description": "DB",
  "peerDependencies": {
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "dotenv": "17.4.2",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "tsconfig": "workspace:*"
  }
}
